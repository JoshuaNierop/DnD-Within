rules_version = '2';

// D&D Within — Firebase Storage rules
// Mirrors the wide-open philosophy of the Realtime Database rules
// (no auth on this hobby app), but constrains writes to image content
// under a known prefix and caps file size to keep the bucket sane.
//
// Time-gate matches database.rules.json (epoch 1808870400000 = 2027-04-28).
service firebase.storage {
  match /b/{bucket}/o {

    // All campaign/character/world imagery lives under images/**.
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.time < timestamp.date(2027, 4, 28)
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.time < timestamp.date(2027, 4, 28);
    }

    // Deny everything outside images/** by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
